					font-size: 28px;
					padding: 30px 15px;
				}

				.entry.clr h3 a[href*="contact"] {
					font-size: 18px;
				}

				.entry.clr h2:contains("Reach us"),
				.entry.clr h2:contains("Social Networks") {
					font-size: 28px;
				}

				.entry.clr h2:contains("Reach us") + ul,
				.entry.clr h2:contains("Social Networks") + ul {
					padding: 25px;
				}

				.entry.clr h2:contains("Social Networks") + ul {
					gap: 15px;
				}

				.entry.clr h2:contains("Social Networks") + ul li a {
					width: 65px;
					height: 65px;
					font-size: 28px;
				}

				.entry.clr h2:contains("Social Networks") + ul li a i {
					font-size: 28px;
				}

				.entry.clr h5:contains("Our CI Logo") ~ p a {
					font-size: 14px;
					padding: 10px 20px;
					margin: 5px;
				}

				.entry.clr h5:contains("Our CI Logo") ~ p a i {
					font-size: 18px;
				}
			}

			/* 소셜 미디어 아이콘 설명 툴팁 추가 */
			.entry.clr h2:contains("Social Networks") + ul li {
				position: relative;
				margin-bottom: 15px;
			}

			.entry.clr h2:contains("Social Networks") + ul li:nth-child(1) a::after {
				content: "YouTube";
				position: absolute;
				bottom: -40px;
				left: 50%;
				transform: translateX(-50%);
				background: rgba(0, 0, 0, 0.9);
				color: white;
				padding: 8px 12px;
				border-radius: 8px;
				font-size: 13px;
				font-weight: 500;
				white-space: nowrap;
				opacity: 0;
				pointer-events: none;
				transition: all 0.3s ease;
				box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
			}

			.entry.clr h2:contains("Social Networks") + ul li:nth-child(2) a::after {
				content: "KakaoTalk";
				position: absolute;
				bottom: -40px;
				left: 50%;
				transform: translateX(-50%);
				background: rgba(0, 0, 0, 0.9);
				color: white;
				padding: 8px 12px;
				border-radius: 8px;
				font-size: 13px;
				font-weight: 500;
				white-space: nowrap;
				opacity: 0;
				pointer-events: none;
				transition: all 0.3s ease;
				box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
			}

			.entry.clr h2:contains("Social Networks") + ul li:nth-child(3) a::after {
				content: "TikTok";
				position: absolute;
				bottom: -40px;
